        </mxCell>
        <mxCell id="d_exit" value="已在均衡：&lt;br&gt;diff_mV &lt;= diff_exit_mV ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="decide_group">
