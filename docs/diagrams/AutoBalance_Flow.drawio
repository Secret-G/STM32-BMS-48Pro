        <mxCell id="ctx1_take" value="获取 ctx 锁&lt;br&gt;g_bms_ctx_mutex" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
