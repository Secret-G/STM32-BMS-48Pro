        <mxCell id="d_refresh" value="刷新周期到期 ?&lt;br&gt;now_ms - bal_last_refresh_ms &gt;= refresh_period_ms" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12" vertex="1" parent="decide_group">
