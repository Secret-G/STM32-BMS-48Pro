        </mxCell>
        <mxCell id="d_start" value="target_count &gt; 0:&lt;br&gt;req.action=START&lt;br&gt;bal_last_refresh_ms=now_ms" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="decide_group">
