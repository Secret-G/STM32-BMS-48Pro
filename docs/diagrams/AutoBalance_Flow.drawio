        <mxCell id="d_refresh_build" value="到期：更新 bal_last_refresh_ms&lt;br&gt;选择阈值 enter/exit&lt;br&gt;parity_enable 时翻转 bal_parity_phase&lt;br&gt;奇偶窗口 + 非相邻贪心，必要时回退全局" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="decide_group">
