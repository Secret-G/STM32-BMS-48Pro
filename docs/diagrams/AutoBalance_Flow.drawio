          <mxGeometry x="185" y="585" width="190" height="88" as="geometry" />
        </mxCell>
        <mxCell id="bm6" value="从所有有效候选中选最高电芯 best_idx" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13" vertex="1" parent="build_group">
