        </mxCell>
        <mxCell id="bm9" value="循环结束：&lt;br&gt;req-&gt;target_count = selected_count&lt;br&gt;target_label = 第一个目标的 VC label&lt;br&gt;返回 0" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13" vertex="1" parent="build_group">
