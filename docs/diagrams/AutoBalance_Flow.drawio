        <mxCell id="runtime_notify" value="通知 ControlTask&lt;br&gt;xSemaphoreGive(g_control_sem)&lt;br&gt;跳过均衡" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
