        <mxCell id="runtime_check" value="读取 runtime_fault&lt;br&gt;BQ76940_AppRuntimeDiagIsFaultActive(app)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
