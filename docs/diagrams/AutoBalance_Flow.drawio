        <mxCell id="ctx2_take" value="获取 ctx 锁&lt;br&gt;Decide 阶段" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="470" y="665" width="240" height="58" as="geometry" />
