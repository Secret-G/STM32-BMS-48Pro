        <mxCell id="runtime_decision" value="runtime_fault != 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="495" y="510" width="190" height="110" as="geometry" />
