<mxfile host="app.diagrams.net">
  <diagram id="AutoBalanceFlowV1" name="AutoBalance Flow">
    <mxGraphModel dx="1600" dy="2200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="自动均衡流程 - BMS_BalanceTask / BQ76940_AppBalance*" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend1" value="绿色：获取/释放 ctx mutex；粉色：获取/释放 I2C mutex；黄色：信号量通知；紫色：判断分支" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="280" y="70" width="620" height="44" as="geometry" />
        </mxCell>

        <mxCell id="start" value="等待 g_balance_sem&lt;br&gt;xSemaphoreTake(portMAX_DELAY)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
