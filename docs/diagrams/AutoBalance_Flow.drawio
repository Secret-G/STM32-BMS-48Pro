        <mxCell id="d_compare" value="新 wr 与 bal_auto_rd 不同 ?&lt;br&gt;不同才 START 重写 CELLBAL&lt;br&gt;相同则 action 保持 NONE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="decide_group">
