          <mxGeometry x="320" y="490" width="170" height="100" as="geometry" />
        </mxCell>
        <mxCell id="d_start_build" value="启动时：全局非相邻贪心&lt;br&gt;候选 &gt;= min_mV + diff_enter&lt;br&gt;最多 3 个目标，映射 VC1/2/5/6/7/10/11/12/15" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="decide_group">
